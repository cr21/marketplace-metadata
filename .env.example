# ─── Google Cloud ────────────────────────────────────────────────────────────

# GCP project that hosts the catalog_registry dataset.
GCP_PROJECT_ID=project-5c016d48-80d5-4534-b69

# BigQuery dataset where registry tables live.
CATALOG_DATASET=catalog_registry

# ─── Credentials ─────────────────────────────────────────────────────────────

# Path to a service-account JSON key file.
# Leave unset to use Application Default Credentials (recommended for local dev):
#   gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Lineage API ─────────────────────────────────────────────────────────────

# Cloud region for the Data Lineage API (must match the dataset region).
LINEAGE_LOCATION=us

# Max concurrent Lineage API calls during a dataset fetch.
LINEAGE_FETCH_CONCURRENCY=4

# ─── JOBS fallback ────────────────────────────────────────────────────────────

# How many days back to scan INFORMATION_SCHEMA.JOBS_BY_PROJECT.
# Max: 180 (BQ retention limit).
JOBS_FALLBACK_LOOKBACK_DAYS=90

# Set to 1 to enable LOW-confidence column-level edges inferred from query text.
# Hidden in the UI by default behind a "Show inferred edges" toggle.
ENABLE_JOBS_COLUMN_INFERENCE=0

# ─── Optional features ───────────────────────────────────────────────────────

# Set to 1 to enable LLM-based PII tagging (added in M07).
ENABLE_LLM_PII=0


# ─── OpenAI enrichment ───────────────────────────────────────────────────────

# OpenAI API key. When set, the crawler calls OpenAI to generate descriptions
# and PII flags for columns/tables that have no description in INFORMATION_SCHEMA.
# When unset, the crawler falls back to heuristic PII tagging only.
OPENAI_API_KEY=
API_KEY=

# OpenAI model used for enrichment (default: gpt-4o-mini — fast, low cost).
OPENAI_MODEL=gpt-4o-mini

# ─── API security ────────────────────────────────────────────────────────────

# Static API key required on every route (sent as X-API-Key header).
# Leave unset in local dev to disable the check entirely.
API_KEY=
